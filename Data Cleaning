SELECT 
    user_id,
    UPPER(TRIM(first_name)) AS clean_first_name,
    LOWER(TRIM(email)) AS clean_email,
    COALESCE(phone, 'No phone provided') AS contact_phone,
    CASE 
        WHEN status IS NULL THEN 'active'
        ELSE status
    END AS status
FROM raw_users
WHERE user_id IS NOT NULL;
