-- CONCAT: Combine strings
SELECT CONCAT(first_name, ' ', last_name) AS full_name FROM users;

-- UPPER/LOWER: Change case
SELECT UPPER(city), LOWER(email) FROM customers;

-- SUBSTRING: Extract part of string
SELECT SUBSTRING(phone, 1, 3) AS area_code FROM contacts;

-- LENGTH: Get string length
SELECT name, LENGTH(name) AS name_length FROM products;

-- TRIM: Remove spaces
SELECT TRIM('  Hello  ') AS trimmed;

-- REPLACE: Replace substring
SELECT REPLACE(description, 'old', 'new') FROM items;

-- LEFT/RIGHT: Get characters from ends
SELECT LEFT(product_code, 2) AS prefix FROM inventory;
